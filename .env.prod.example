# Copy to .env.prod on the server and fill in. NEVER commit .env.prod.
#
# Public domain (Caddy gets a Let's Encrypt cert for it). For a VPS without a
# bought domain, use sslip.io: <SERVER_IP>.sslip.io (resolves to the IP, no DNS setup).
HCOS_DOMAIN=203.0.113.10.sslip.io

# Full public base URL (same host, https). Used to build the frontend's API base.
PUBLIC_BASE_URL=https://203.0.113.10.sslip.io

# Postgres
POSTGRES_USER=hcos
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=hcos

# Backend secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Comma-separated emails auto-granted the admin role (bootstrap). These emails
# become admin on registration and are kept admin on startup. The only way to
# get the first admin now that registration always creates plain employees.
INITIAL_ADMIN_EMAILS=

LOG_LEVEL=INFO

# Leave empty for the single-origin deploy (no CORS needed). Only set for split
# frontend/backend hosting, e.g. CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=

# --- DB backups (db-backup sidecar) ---
# Nightly pg_dump into ./backups on the host. Defaults are fine; override here.
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
# Set a passphrase to AES-256-encrypt dumps at rest (recommended). Generate with
# openssl rand -hex 32. Keep it safe — without it encrypted backups can't be
# restored. Leave empty for plain gzip dumps.
BACKUP_ENCRYPTION_PASSPHRASE=
